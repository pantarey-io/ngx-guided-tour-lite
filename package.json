{
  "name": "@pantarey.io/ngx-guided-tour-lite",
  "version": "0.1.0",
  "description": "A lightweight, dependency-free library for creating guided product tours for Angular",
  "author": "Pantarey GmbH <info@pantarey.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pantarey-io/ngx-guided-tour-lite.git"
  },
  "bugs": {
    "url": "https://github.com/pantarey-io/ngx-guided-tour-lite/issues"
  },
  "homepage": "https://github.com/pantarey-io/ngx-guided-tour-lite#readme",
  "keywords": [
    "angular",
    "guided-tour",
    "onboarding",
    "product-tour",
    "walkthrough",
    "tour",
    "spotlight",
    "lightweight",
    "ngx"
  ],
  "peerDependencies": {
    "@angular/core": ">=19.0.0"
  },
  "sideEffects": false,
  "module": "dist/index.mjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/bundle.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "typescript": "~5.6.0"
  }
}